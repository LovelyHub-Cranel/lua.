local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Player = Players.LocalPlayer

local autoStruggleConn = nil
local lastStruggleTime = 0
local lastAnchorTime = 0

-- Güvenli değerler (FTAP anti-cheat'e daha az takılır)
local STRUGGLE_COOLDOWN = 0.26     -- 0.27'den biraz düşürdük ama hala güvenli
local ANCHOR_DEBOUNCE   = 0.38     -- Anchor spam'ini önler
local VELOCITY_DOWN     = -72      -- Yere yapıştırma için dengeli değer

Defance2Tab:CreateToggle({
    Name = "Anti Loop Kick",
    CurrentValue = false,
    Flag = "antigrab_loopkick_safe",

    Callback = function(Value)
        if autoStruggleConn then
            autoStruggleConn:Disconnect()
            autoStruggleConn = nil
        end

        if not Value then
            -- Kapatıldığında anchor'ları temizle
            local char = Player.Character
            if char then
                for _, part in pairs(char:GetChildren()) do
                    if part:IsA("BasePart") then
                        part.Anchored = false
                    end
                end
            end
            return
        end

        -- Struggle Remote'u bul (FTAP standart yolu)
        local CharacterEvents = ReplicatedStorage:FindFirstChild("CharacterEvents")
        local Struggle = CharacterEvents and CharacterEvents:FindFirstChild("Struggle")

        autoStruggleConn = RunService.Heartbeat:Connect(function()
            local char = Player.Character
            if not char or not char:FindFirstChild("Head") then return end

            local head = char.Head
            local partOwner = head:FindFirstChild("PartOwner")

            -- FTAP grab algılama (PartOwner + IsHeld)
            local isGrabbed = false
            if partOwner and partOwner.Value ~= Player.Name then
                isGrabbed = true
            end

            local isHeld = Player:FindFirstChild("IsHeld")
            if isHeld and isHeld.Value then
                isGrabbed = true
            end

            if isGrabbed then
                -- Struggle (doğru argüman ile)
                if Struggle and tick() - lastStruggleTime > STRUGGLE_COOLDOWN then
                    lastStruggleTime = tick()
                    pcall(function()
                        Struggle:FireServer(Player)
                    end)
                end

                -- GameCorrectionEvents varsa velocity sıfırla
                pcall(function()
                    local gce = ReplicatedStorage:FindFirstChild("GameCorrectionEvents")
                    if gce then
                        local stopVel = gce:FindFirstChild("StopAllVelocity")
                        if stopVel then
                            stopVel:FireServer()
                        end
                    end
                end)

                -- Anchor + yere çekme (debounce ile)
                if tick() - lastAnchorTime > ANCHOR_DEBOUNCE then
                    lastAnchorTime = tick()

                    -- Tüm parçaları anchor'la (grab'ı kırar)
                    for _, part in pairs(char:GetChildren()) do
                        if part:IsA("BasePart") then
                            part.Anchored = true
                        end
                    end

                    -- Ekstra yere yapıştırma
                    local root = char:FindFirstChild("HumanoidRootPart")
                    if root then
                        root.AssemblyLinearVelocity = Vector3.new(0, VELOCITY_DOWN, 0)
                        root.AssemblyAngularVelocity = Vector3.zero
                    end

                    -- Humanoid state reset (ragdoll/kick önleme)
                    local hum = char:FindFirstChildOfClass("Humanoid")
                    if hum then
                        pcall(function()
                            hum.PlatformStand = false
                            hum:ChangeState(Enum.HumanoidStateType.GettingUp)
                        end)
                    end
                end
            else
                -- Grab bittiğinde anchor'ı kaldır (gecikmeli)
                if tick() - lastAnchorTime > 0.45 then
                    for _, part in pairs(char:GetChildren()) do
                        if part:IsA("BasePart") then
                            part.Anchored = false
                        end
                    end
                end
            end
        end)
    end
})

