local function runGucciSetup()

    local Char = LP.Character or LP.CharacterAdded:Wait()
    local Hum = Char:WaitForChild("Humanoid")
    local HRP = Char:WaitForChild("HumanoidRootPart")

    local OldPos = HRP.Position

    -- Spawn Blobman
    pcall(function()
        RS.MenuToys.SpawnToyRemoteFunction:InvokeServer(
            "CreatureBlobman",
            CFrame.new(0,50000,0),
            Vector3.new(0,60,0)
        )
    end)

    -- Toy spawn bekleme
    local toyFolder = workspace:WaitForChild(LP.Name.."SpawnedInToys",5)
    if not toyFolder then return end

    local bman = toyFolder:WaitForChild("CreatureBlobman",5)
    if not bman then return end

    local head = bman:FindFirstChild("Head")
    local seat = bman:FindFirstChildWhichIsA("VehicleSeat")

    if head then
        head.CFrame = CFrame.new(0,50000,0)
        head.Anchored = true
    end

    if seat then
        HRP.CFrame = seat.CFrame + Vector3.new(0,2,0)
        task.wait(0.05)
        seat:Sit(Hum)
        GucciConfig.isSitting = true
    end

    -- Jump ile geri dönme
    Hum:GetPropertyChangedSignal("Jump"):Connect(function()
        if GucciConfig.isSitting and Hum.Jump then
            HRP.CFrame = CFrame.new(OldPos)
            GucciConfig.isSitting = false
        end
    end)

    -- Loop
    if GucciConfig.ragdollConn then
        GucciConfig.ragdollConn:Disconnect()
    end

    GucciConfig.ragdollConn = RunService.Heartbeat:Connect(function()
        if GucciConfig.enabled and GucciConfig.isSitting then
            pcall(function()
                RS.CharacterEvents.RagdollRemote:FireServer(HRP,0)
            end)
        end
    end)

end


