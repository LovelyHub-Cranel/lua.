						if obj.Name == "Pyramid" then
							obj.CanTouch = false;
							obj.CanCollide = false;
							obj.CanQuery = false;
							obj.Transparency = 0
							if not obj:FindFirstChild("Highlight") then
								local high = Instance.new("Highlight", obj)
								high.FillColor = Color3.fromRGB(0, 0, 0)
							end
						elseif obj.Name == "Main" then
							obj.CanTouch = false;
							obj.CanCollide = false;
							obj.CanQuery = false;
							obj.Transparency = 0
							if not obj:FindFirstChild("Highlight") then
								local high = Instance.new("Highlight", obj)
								high.FillColor = Color3.fromRGB(124, 213, 133)
							end
						elseif obj:IsA("BasePart") then
							obj.CanTouch = false;
							obj.CanCollide = false;
							obj.CanQuery = false;
							obj.Transparency = 1
						end
					end
				end
				local function SpawnToy(name)
					local t = tick()
					while not canSpawn.Value do
						if not _G.KatanaAnti or tick() - t > 1 then
							return nil
						end
						task.wait(0.01)
					end
					local currentHRP = getHRP()
					if currentHRP then
						task.spawn(function()
							pcall(function()
								spawnRemote:InvokeServer(name, currentHRP.CFrame * CFrame.new(0, -1, 20), Vector3.new(0, 0, 0))
							end)
						end)
					end
					local boolik, house = CheckForHome()
					local inv = workspace:FindFirstChild(plr.Name .. "SpawnedInToys")
					if boolik and house then
						return house:WaitForChild(name, 2)
					elseif not workspace.PlotItems.PlayersInPlots:FindFirstChild(plr.Name) and inv then
						return inv:WaitForChild(name, 2)
					end
					return nil
				end
				while _G.KatanaAnti do
					task.wait(0.001)

	                -- SprayCanWD koruma
                    pcall(function()
	                    local inv = workspace:FindFirstChild(plr.Name .. "SpawnedInToys")
	                    if inv then
		                    local kat = inv:FindFirstChild("Anti") or inv:FindFirstChild("NinjaKatana")
		                    if kat and kat:FindFirstChild("StickyPart") then
			                    StickKatana(kat)
		                    end
	                    end
                    end)
					if not plr.Character or not plr.Character:FindFirstChild("Humanoid") or plr.Character.Humanoid.Health <= 0 then
						continue
					end
					local inv = workspace:FindFirstChild(plr.Name .. "SpawnedInToys")
					local katana = inv and inv:FindFirstChild("NinjaKatana")
					if workspace.PlotItems.PlayersInPlots:FindFirstChild(plr.Name) then
						local boolik, house = CheckForHome()
						if boolik and house and workspace.Plots:FindFirstChild(house.Name) then
							local sign = workspace.Plots[house.Name]:FindFirstChild("PlotSign")
							if sign and sign.ThisPlotsOwners.Value.TimeRemainingNum.Value > 89 then
								katana = SpawnToy("NinjaKatana")
								if katana == nil then
									continue
								end
								katana.Name = "Anti"
								StickKatana(katana)
							end
						end
					end
					if not katana then
						if workspace.PlotItems.PlayersInPlots:FindFirstChild(plr.Name) then
							continue
						end
						katana = SpawnToy("NinjaKatana")
						if katana == nil then
							continue
						end
						katana.Name = "Anti"
						if not katana then
							continue
						end
					end
					repeat
						if katana and katana:FindFirstChild("StickyPart") and katana.StickyPart.CanTouch == true then
							StickKatana(katana)
							katana.Name = "Anti"
						end
						task.wait(0.3)
					until not katana or not _G.KatanaAnti
							or not katana:FindFirstChild("StickyPart")
							or katana.StickyPart.CanTouch == false 
							or not plr.Character or not plr.Character:FindFirstChild("HumanoidRootPart") 
							or not katana:FindFirstChild("StickyPart") 
							or (plr.Character.HumanoidRootPart.Position - katana.StickyPart.Position).Magnitude >= 20
					if not katana or not katana:FindFirstChild("StickyPart") or not plr.Character or not plr.Character:FindFirstChild("HumanoidRootPart") or (plr.Character.HumanoidRootPart.Position - katana.StickyPart.Position).Magnitude >= 20 then
						ClearKatana()
					end
					pcall(function()
						repeat
							task.wait(0.01)
						until not _G.KatanaAnti or not plr.Character or not plr.Character:FindFirstChild("Humanoid") or not katana or not katana:FindFirstChild("StickyPart") or not katana.StickyPart:FindFirstChild("StickyWeld") or not katana.StickyPart.StickyWeld.Part1
						if not katana or not katana:FindFirstChild("StickyPart") or (plr.Character and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health <= 0) or not katana["StickyPart"]:FindFirstChild("StickyWeld").Part1 then
							ClearKatana()
						end
					end)
				end
			end)
		else
			_G.KatanaAnti = false
			ClearKatana()
		end
	end
})

