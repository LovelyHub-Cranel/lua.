local function getRootAndHum()
    local char = Player.Character
    if not char then return nil, nil end
    return char:FindFirstChild("HumanoidRootPart"), char:FindFirstChildOfClass("Humanoid")
end

local function forceToGround(root, hum, reason)
    if not root then return end
    
    local safeCFrame = CFrame.new(root.Position.X, GROUND_Y, root.Position.Z) * root.CFrame.Rotation
    root.CFrame = safeCFrame
    
    root.AssemblyLinearVelocity = Vector3.new(0, -120, 0)   -- Daha sert yere yapışma
    root.AssemblyAngularVelocity = Vector3.new()
    
    if hum then
        hum.PlatformStand = false
        hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
        hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
        hum:ChangeState(Enum.HumanoidStateType.GettingUp)
        task.delay(0.1, function()
            hum:ChangeState(Enum.HumanoidStateType.Running)
        end)
    end
    
    Antivoidmesssage(reason or "Yüksekten / Grab'dan kurtarıldın!")
end

local function startStruggleSpam()
    if struggleSpamConn then struggleSpamConn:Disconnect() end
    
    struggleSpamConn = RunService.Heartbeat:Connect(function()
        local char = Player.Character
        if not char then return end
        
        local isHeld = Player:FindFirstChild("IsHeld") or Player:FindFirstChild("Grabbed") -- fallback isim
        if isHeld and isHeld.Value == true then
            if StruggleEvent then
                pcall(function()
                    StruggleEvent:FireServer()
                    task.wait(0.01)  -- Daha hızlı spam, ama kick riski artar
                    StruggleEvent:FireServer()
                end)
            end
            
            local root = char:FindFirstChild("HumanoidRootPart")
            if root then
                root.AssemblyLinearVelocity = Vector3.new(0, -150, 0)  -- Çok sert aşağı çek
                root.AssemblyAngularVelocity = Vector3.new()
                
                -- Ownership geri alma denemesi (loop grab'e karşı ekstra)
                pcall(function()
                    ReplicatedStorage.GrabEvents.SetNetworkOwner:FireServer(root, nil)  -- Server'a bırakmaya çalış
                end)
            end
            
            Antivoidmesssage("Grab / Kick spam algılandı - Struggle aktif!")
        end
    end)
end

local function highAndGrabCheck()
    if not isEnabled then return end
    
    local root, hum = getRootAndHum()
    if not root or not hum then return end
    
    -- Yüksekte mi?
    if root.Position.Y > MAX_SAFE_HEIGHT then
        forceToGround(root, hum, "Yüksek fling engellendi!")
    end
    
    -- Grab / kick spam kontrolü
    local isHeld = Player:FindFirstChild("IsHeld") or Player:FindFirstChild("Grabbed")
    if isHeld and isHeld.Value then
        root.AssemblyLinearVelocity = Vector3.new(
            root.AssemblyLinearVelocity.X * 0.05,
            -150,  -- Çok agresif yere çek
            root.AssemblyLinearVelocity.Z * 0.05
        )
        Antivoidmesssage("Grab yakalandı - Yere yapıştırılıyor!")
    end
    
    -- Black hole / kick uyarısı (eğer varsa)
    local blackHole = workspace:FindFirstChild("BlackHole") or workspace:FindFirstChildWhichIsA("Part", true) -- isim değişebilir
    if blackHole and blackHole.Name:lower():find("black") and (root.Position - blackHole.Position).Magnitude < 60 then
        forceToGround(root, hum, "Black hole algılandı - Hemen yere!")
    end
end

