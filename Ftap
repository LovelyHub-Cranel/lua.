local AntiBlobmanEnabled = false

local function EnableAntiBlobman()
    if AntiBlobmanEnabled then return end
    AntiBlobmanEnabled = true
    
    -- zaten spawn olmuş olanları da temizle
    for _, obj in workspace:GetDescendants() do
        if obj.Name == "CreatureBlobman" then
            if obj:FindFirstChild("LeftDetector") then
                obj.LeftDetector:Destroy()
            end
            if obj:FindFirstChild("RightDetector") then
                obj.RightDetector:Destroy()
            end
        end
    end
    
    -- yeni spawn olanları yakala
    local connection
    connection = workspace.DescendantAdded:Connect(function(child)
        if not AntiBlobmanEnabled then
            connection:Disconnect()
            return
        end
        
        if child.Name == "CreatureBlobman" then
            task.delay(0.1, function()  -- biraz beklemek genelde daha güvenli
                if child.Parent and child:FindFirstChild("LeftDetector") then
                    child.LeftDetector:Destroy()
                end
                if child.Parent and child:FindFirstChild("RightDetector") then
                    child.RightDetector:Destroy()
                end
            end)
        end
    end)
    
    -- toggle kapatıldığında bağlantıyı temizlemek için
    getgenv().AntiBlobmanConnection = connection
end

local function DisableAntiBlobman()
    AntiBlobmanEnabled = false
    if getgenv().AntiBlobmanConnection then
        getgenv().AntiBlobmanConnection:Disconnect()
        getgenv().AntiBlobmanConnection = nil
    end
end

