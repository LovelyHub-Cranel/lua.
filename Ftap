local GROUND_Y = 5                -- Zemin seviyesi (haritaya göre 0-10)
local CHECK_INTERVAL = 0.07       -- Biraz yavaşlattım, anti-cheat'e daha az takılır
local MESSAGE_COOLDOWN = 2.5      -- Bildirim spam önleme (saniye)

