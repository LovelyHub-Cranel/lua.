local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local plr = Players.LocalPlayer
local spawnRemote = ReplicatedStorage.MenuToys.SpawnToyRemoteFunction
local stickyEvent = ReplicatedStorage.PlayerEvents.StickyPartEvent
local setOwner = ReplicatedStorage.GrabEvents.SetNetworkOwner

_G.KatanaAnti = _G.KatanaAnti or false

local function getHRP()
	local char = plr.Character or plr.CharacterAdded:Wait()
	return char:WaitForChild("HumanoidRootPart")
end

local function getInventory()
	return workspace:FindFirstChild(plr.Name.."SpawnedInToys")
end

local function getKatana()
	local inv = getInventory()
	if not inv then return end
	return inv:FindFirstChild("Anti") or inv:FindFirstChild("NinjaKatana")
end

local function spawnKatana()
	local hrp = getHRP()
	pcall(function()
		spawnRemote:InvokeServer(
			"NinjaKatana",
			hrp.CFrame * CFrame.new(0,0,20),
			Vector3.new(0,0,0)
		)
	end)
end

local function forceOwner(katana)
	local sound = katana:FindFirstChild("SoundPart")
	if sound then
		pcall(function()
			setOwner:FireServer(sound, sound.CFrame)
		end)
	end
end

local function stickKatana(katana)

	local sticky = katana:FindFirstChild("StickyPart")
	local hrp = getHRP()
	local firePart = hrp:FindFirstChild("FirePlayerPart")

	if sticky and firePart then
		pcall(function()
			stickyEvent:FireServer(
				sticky,
				firePart,
				CFrame.new() * CFrame.Angles(0,math.rad(90),math.rad(90))
			)
		end)
	end

end

local function protectParts(katana)

	for _,v in pairs(katana:GetDescendants()) do
		if v:IsA("BasePart") then
			v.CanTouch = false
			v.CanCollide = false
			v.CanQuery = false
		end
	end

end

task.spawn(function()

	while task.wait(0.03) do

		if not _G.KatanaAnti then
			continue
		end

		local char = plr.Character
		if not char then
			continue
		end

		local hum = char:FindFirstChild("Humanoid")
		if not hum or hum.Health <= 0 then
			continue
		end

		local katana = getKatana()

		if not katana then
			spawnKatana()
			continue
		end

		katana.Name = "Anti"

		local sticky = katana:FindFirstChild("StickyPart")

		if sticky then

			local weld = sticky:FindFirstChild("StickyWeld")

			if not weld or sticky.CanTouch then
				stickKatana(katana)
			end

			if (getHRP().Position - sticky.Position).Magnitude > 15 then
				stickKatana(katana)
			end

		end

		forceOwner(katana)

		protectParts(katana)

	end

end)
