-- Animasyonlar
local function animateGradient()
	spawn(function()
		while mainFrame.Parent do
			for i = 0, 360, 2 do
				if not mainFrame.Parent then break end
				gradient.Rotation = i
				wait(0.03)
			end
		end
	end)
end

local function animateLogo()
	local tweenInfo = TweenInfo.new(2, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut, -1, true)
	local scaleTween = TweenService:Create(logoImage, tweenInfo, {Size = UDim2.new(0, 160, 0, 160)})
	scaleTween:Play()
	
	local glowTween = TweenService:Create(logoGlow, tweenInfo, {ImageTransparency = 0.7})
	glowTween:Play()
end

local loadingSteps = {
	{text = "Initializing...", percent = 0},
	{text = "Connecting to Roblox...", percent = 20},
	{text = "Loading Script Engine...", percent = 40},
	{text = "Injecting Scripts...", percent = 60},
	{text = "Verifying Security...", percent = 80},
	{text = "Ready to Execute!", percent = 100}
}

local function startLoading()
	for i, step in ipairs(loadingSteps) do
		statusLabel.Text = step.text
		percentLabel.Text = step.percent .. "%"
		
		local tweenInfo = TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
		local targetSize = UDim2.new(step.percent / 100, 0, 1, 0)
		local tween = TweenService:Create(progressBar, tweenInfo, {Size = targetSize})
		tween:Play()
		
		wait(0.8)
	end
	
	-- Yükleme tamamlandı, başarı ekranını göster
	wait(0.5)
	
	local fadeOut = TweenService:Create(loadingContainer, TweenInfo.new(0.5), {Position = UDim2.new(0.5, -200, 0.5, -300)})
	fadeOut:Play()
	
	wait(0.3)
	
	loadingContainer.Visible = false
	successContainer.Visible = true
	successContainer.Position = UDim2.new(0.5, -200, 0.5, -150)
	
	local fadeIn = TweenService:Create(successContainer, TweenInfo.new(0.5), {Position = UDim2.new(0.5, -200, 0.5, -200)})
	fadeIn:Play()
end

-- Button Hover Efekti
executeButton.MouseEnter:Connect(function()
	local hoverTween = TweenService:Create(executeButton, TweenInfo.new(0.2), {Size = UDim2.new(0.92, 0, 0, 52)})
	hoverTween:Play()
end)

executeButton.MouseLeave:Connect(function()
	local leaveTween = TweenService:Create(executeButton, TweenInfo.new(0.2), {Size = UDim2.new(0.9, 0, 0, 50)})
	leaveTween:Play()
end)

-- Button Click
executeButton.MouseButton1Click:Connect(function()
	-- Buton tıklanınca GUI'yi kapat
	local closeTween = TweenService:Create(mainFrame, TweenInfo.new(0.5), {BackgroundTransparency = 1})
	closeTween:Play()
	
	for _, child in ipairs(mainFrame:GetDescendants()) do
		if child:IsA("GuiObject") then
			TweenService:Create(child, TweenInfo.new(0.5), {
				BackgroundTransparency = 1,
				TextTransparency = 1,
				ImageTransparency = 1
			}):Play()
		end
	end
	
	wait(0.5)
	screenGui:Destroy()
	
	-- Buraya kendi scriptinizi ekleyebilirsiniz
	print("Lovely-Hub Script Executed!")
end)

-- Başlat
animateGradient()
animateLogo()
wait(0.5)
startLoading()
