-- Ring rotation
local function rotateRing(ring,duration,dir)
	while screenGui.Parent do
		local tween = TweenService:Create(ring,TweenInfo.new(duration,Enum.EasingStyle.Linear),{Rotation = ring.Rotation + (360*dir)})
		tween:Play()
		tween.Completed:Wait()
	end
end

task.spawn(function() rotateRing(ring1,3,1) end)
task.spawn(function() rotateRing(ring2,5,-1) end)

-- Loading
local function startLoading()

	local total = 6
	local steps = #loadingStates
	local stepTime = total/steps

	for i,state in ipairs(loadingStates) do

		statusText.Text = state

		local percent = (i/steps)*100
		local size = UDim2.new(percent/100,0,1,0)

		TweenService:Create(progressBar,TweenInfo.new(stepTime),{Size=size}):Play()

		percentText.Text = math.floor(percent).."%"
		task.wait(stepTime)

	end

	task.wait(0.5)

	-- Fade
	local fade = TweenInfo.new(0.8)

	for _,v in pairs(mainFrame:GetDescendants()) do

		if v:IsA("TextLabel") then
			TweenService:Create(v,fade,{TextTransparency=1}):Play()

		elseif v:IsA("ImageLabel") then
			TweenService:Create(v,fade,{ImageTransparency=1}):Play()

		elseif v:IsA("Frame") then
			TweenService:Create(v,fade,{BackgroundTransparency=1}):Play()
		end
	end

	TweenService:Create(blur,fade,{Size=0}):Play()

	task.wait(1)

	blur:Destroy()
	screenGui:Destroy()

	print("Lovely Hub Loaded")

end

startLoading()
