-- Ana yükleme animasyonu
local totalDuration = 6 -- 6 saniye
local startTime = tick()
local loadingMessages = {
    "Initializing components",
    "Loading assets", 
    "Preparing scripts",
    "Connecting to server",
    "Injecting code",
    "Finalizing setup",
    "Complete"
}

local connection
connection = RunService.Heartbeat:Connect(function()
    local elapsed = tick() - startTime
    local progress = math.clamp(elapsed / totalDuration, 0, 1)
    
    -- Progress bar güncelle
    progressFill.Size = UDim2.fromScale(progress, 1)
    percentLabel.Text = math.floor(progress * 100) .. "%"
    
    -- Status mesajı güncelle
    local messageIndex = math.min(math.floor(progress * #loadingMessages) + 1, #loadingMessages)
    local baseMessage = loadingMessages[messageIndex]
    statusLabel.Text = baseMessage .. dots
    
    -- Tamamlandığında kapat
    if progress >= 1 then
        connection:Disconnect()
        
        -- Son dokunuş: tam ekran fade out
        local fadeInfo = TweenInfo.new(1.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
        local fadeTween = TweenService:Create(mainFrame, fadeInfo, {BackgroundTransparency = 1})
        
        -- Tüm çocukları da fade yap
        for _, child in pairs(mainFrame:GetDescendants()) do
            if child:IsA("GuiObject") then
                TweenService:Create(child, fadeInfo, {BackgroundTransparency = 1, TextTransparency = 1, ImageTransparency = 1}):Play()
            end
        end
        
        fadeTween:Play()
        fadeTween.Completed:Wait()
        
        screenGui:Destroy()
        
        -- Oyun içi UI'ı göster (eğer varsa)
        playerGui:SetTopbarTransparency(0)
    end
end)

-- ESC ile atlama (test için)
local UserInputService = game:GetService("UserInputService")
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if input.KeyCode == Enum.KeyCode.Escape and not gameProcessed then
        if connection then
            connection:Disconnect()
        end
        screenGui:Destroy()
    end
end)

