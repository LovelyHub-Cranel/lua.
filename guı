-- Loading States
local loadingStates = {
	"Initializing...",
	"Loading assets...",
	"Preparing scripts...",
	"Connecting to server...",
	"Injecting code...",
	"Almost done...",
	"Complete!"
}

-- Animasyon fonksiyonları
local function rotateRing(ring, duration, direction)
	local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut, -1)
	
	while screenGui.Parent do
		local startRotation = ring.Rotation
		local endRotation = startRotation + (360 * direction)
		
		local tween = TweenService:Create(ring, tweenInfo, {Rotation = endRotation})
		tween:Play()
		task.wait(duration)
	end
end

-- Halkaları döndür
task.spawn(function() rotateRing(ring1, 3, 1) end)
task.spawn(function() rotateRing(ring2, 5, -1) end)

-- Logo pulse efekti
