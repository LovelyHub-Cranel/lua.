	while screenGui.Parent do
		local tweenInfo = TweenInfo.new(2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true)
		local tween = TweenService:Create(logo, tweenInfo, {ImageTransparency = 0.1})
		tween:Play()
		task.wait(4)
	end
end)

-- Main Loading Function
local function startLoading()
	local totalDuration = 6
	local steps = #loadingStates
	local stepDuration = totalDuration / steps
	
	for i, state in ipairs(loadingStates) do
		-- Durum textini güncelle
		statusText.Text = state
		
		-- Progress bar güncelle
		local targetPercent = (i / steps) * 100
		local targetSize = UDim2.new(targetPercent / 100, 0, 1, 0)
		
		local tweenInfo = TweenInfo.new(stepDuration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
		local progressTween = TweenService:Create(progressBar, tweenInfo, {Size = targetSize})
		progressTween:Play()
		
		-- Yüzce textini güncelle
		task.spawn(function()
			local startPercent = tonumber(string.match(percentText.Text, "%d+")) or 0
			local startTime = tick()
			
			while tick() - startTime < stepDuration do
				local elapsed = tick() - startTime
				local currentPercent = math.floor(startPercent + ((targetPercent - startPercent) * (elapsed / stepDuration)))
				percentText.Text = currentPercent .. "%"
				task.wait()
			end
			percentText.Text = math.floor(targetPercent) .. "%"
		end)
		
		task.wait(stepDuration)
	end
	
	-- Loading tamamlandı - Fade out
	task.wait(0.5)
	
	local fadeInfo = TweenInfo.new(0.8, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	local fadeTween = TweenService:Create(mainFrame, fadeInfo, {
		BackgroundTransparency = 1
	})
	
	-- Tüm elementleri fade yap
	for _, child in ipairs(mainFrame:GetChildren()) do
		if child:IsA("TextLabel") then
			TweenService:Create(child, fadeInfo, {TextTransparency = 1}):Play()
		elseif child:IsA("ImageLabel") then
			TweenService:Create(child, fadeInfo, {ImageTransparency = 1}):Play()
		elseif child:IsA("Frame") and child.Name ~= "MainFrame" then
			TweenService:Create(child, fadeInfo, {BackgroundTransparency = 1}):Play()
		end
	end
	
	fadeTween:Play()
	fadeTween.Completed:Wait()
	
	-- GUI'yi sil
	screenGui:Destroy()
	
	print("Lovely-Hub loaded successfully!")
end

-- Başlat
startLoading()
